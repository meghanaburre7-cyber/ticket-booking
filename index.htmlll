<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticket Booking System</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <h1>Ticket Booking System</h1>
        <p>Book Bus, Train, Flight, and Movie Tickets Online</p>
    </header>

    <main>
        <section class="booking-form">
            <h2>Book Your Ticket</h2>

            <form id="ticketForm">
                <label for="ticketType">Ticket Type</label>
                <select id="ticketType" required>
                    <option value="">Select Ticket Type</option>
                    <option value="Bus">Bus</option>
                    <option value="Train">Train</option>
                    <option value="Flight">Flight</option>
                    <option value="Movie">Movie</option>
                </select>

                <label for="fromLocation">From</label>
                <input type="text" id="fromLocation" placeholder="Enter departure location" required>

                <label for="toLocation">To</label>
                <input type="text" id="toLocation" placeholder="Enter destination" required>

                <label for="travelDate">Travel Date</label>
                <input type="date" id="travelDate" required>

                <label for="passengers">Number of Tickets</label>
                <input type="number" id="passengers" min="1" max="10" value="1" required>

                <button type="button" onclick="bookTicket()">
                    Book Ticket
                </button>
            </form>
        </section>

        <section class="booking-summary">
            <h2>Booking Details</h2>
            <div id="result">
                <p>Your booking details will appear here.</p>
            </div>
        </section>
    </main>

    <footer>
        <p>&copy; 2026 Ticket Booking System. All Rights Reserved.</p>
    </footer>

    <script src="script.js"></script>

</body>
</html>
